# Server-side only — never exposed to the browser.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Stripe — test mode keys while building/testing (sk_test_...), swap to
# live keys (sk_live_...) only when ready to accept real payments.
# Get keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# Price ID for the "MTDPrep Standard" recurring subscription price.
# Stripe Dashboard → Product catalog → Products → Add product → Add price →
# Recurring → copy the price_... ID it generates.
STRIPE_PRICE_ID=

# The public URL of this app, used for Stripe Checkout success/cancel
# redirects. Use http://localhost:3000 for local testing, and
# https://app.mtdprep.co.uk in production.
NEXT_PUBLIC_APP_URL=
